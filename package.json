{
  "name": "hvtl-irs",
  "private": true,
  "version": "1.0.0",
  "description": "Industrial Risk Management System for high-voltage transmission lines",
  "author": "PR Ahmed",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "electron:build": "vite build && electron-builder",
    "electron:dev": "electron ."
  },
  "dependencies": {
    "axios": "^1.18.1",
    "electron-squirrel-startup": "^1.0.1",
    "i18next": "^26.3.4",
    "i18next-http-backend": "^4.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.21.0",
    "primereact": "^10.9.8",
    "react": "^19.2.6",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0",
    "react-toastify": "^11.1.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "config": {
    "forge": "./forge.config.cjs"
  },
  "build": {
    "appId": "com.hvtl.irs",
    "productName": "HVTL IRS",
    "directories": {
      "output": "C:/hvtl_build"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "build/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HVTL IRS"
    }
  }
}
